{
  // Run these via: Terminal > Run Task...  (or Cmd+Shift+B for the default).
  // Most tasks prompt for which app to target.
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Maestro: Setup (install/check tooling)",
      "type": "shell",
      "command": "./scripts/setup.sh",
      "problemMatcher": []
    },
    {
      "label": "Maestro: Run suite",
      "type": "shell",
      "command": "./scripts/run.sh ${input:app}",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "Maestro: Run smoke",
      "type": "shell",
      "command": "./scripts/run.sh ${input:app} smoke",
      "problemMatcher": []
    },
    {
      "label": "Maestro: Run single flow",
      "type": "shell",
      "command": "./scripts/run.sh ${input:app} ${input:flow}",
      "problemMatcher": []
    },
    {
      "label": "Maestro: Debug flow (continuous)",
      "type": "shell",
      "command": "./scripts/debug.sh ${input:app} ${input:flow}",
      "problemMatcher": []
    },
    {
      "label": "Maestro: Debug naukri login (continuous)",
      "type": "shell",
      "command": "./scripts/debug.sh naukri login/login-with-password.yaml",
      "problemMatcher": []
    },
    {
      "label": "Maestro: Run naukri login",
      "type": "shell",
      "command": "./scripts/run.sh naukri login/login-with-password.yaml",
      "problemMatcher": []
    },
    {
      "label": "Maestro: Report (build & open)",
      "type": "shell",
      "command": "./scripts/report.sh ${input:app}",
      "problemMatcher": []
    },
    {
      "label": "Maestro: Inspect (Studio)",
      "type": "shell",
      "command": "./scripts/inspect.sh studio",
      "problemMatcher": []
    },
    {
      "label": "Maestro: Inspect (hierarchy)",
      "type": "shell",
      "command": "./scripts/inspect.sh hierarchy",
      "problemMatcher": []
    },
    {
      "label": "ADB: List devices",
      "type": "shell",
      "command": "adb devices -l",
      "problemMatcher": []
    },
    {
      "label": "Keyboard: Use ADBKeyboard (for text input)",
      "type": "shell",
      "command": "./scripts/keyboard.sh use-adb",
      "problemMatcher": []
    },
    {
      "label": "Keyboard: Restore normal keyboard",
      "type": "shell",
      "command": "./scripts/keyboard.sh restore",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "app",
      "type": "pickString",
      "description": "Which app?",
      "options": ["naukri", "app-one", "app-two"],
      "default": "naukri"
    },
    {
      "id": "flow",
      "type": "promptString",
      "description": "Flow path relative to flows/<app>/ (e.g. login/login-with-password.yaml)",
      "default": "login/login-with-password.yaml"
    }
  ]
}
