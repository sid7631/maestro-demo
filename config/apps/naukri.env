# --- naukri --------------------------------------------------------------
# Naukri Android app. Note: its application id is not reverse-domain style.

APP_ID=naukriApp.appModules.login
PLATFORM=android

# App is installed on the device already, so no binary to install.
ANDROID_APP_BINARY=
IOS_APP_BINARY=

# Variables forwarded into flows via `maestro -e`. Their VALUES live in
# config/apps/naukri.local.env (gitignored) — never commit credentials.
MAESTRO_FORWARD="USERNAME PASSWORD"
