# --- app-one -------------------------------------------------------------
# Example Android-first app. Copy this file to add a new app.

# Application / bundle id. Injected into flows as ${APP_ID}.
APP_ID=com.facebook.katana

# Default platform for this app: android | ios
PLATFORM=android

# App build to install before testing, relative to the repo root.
# Leave blank to skip install and assume the app is already on the device.
ANDROID_APP_BINARY=binaries/app-one.apk
IOS_APP_BINARY=
