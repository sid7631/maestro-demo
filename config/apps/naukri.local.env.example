# Copy this file to "naukri.local.env" (which is gitignored) and fill in real
# test-account credentials. These get forwarded into flows as ${USERNAME} /
# ${PASSWORD} (see MAESTRO_FORWARD in naukri.env).
#
#   cp config/apps/naukri.local.env.example config/apps/naukri.local.env
#
USERNAME=your-test-account@example.com
PASSWORD=your-test-password
